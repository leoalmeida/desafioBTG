@startuml container_diagram

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title BTG - Diagrama de Containers

Person(user, "Usuario")

System_Boundary(system, "Plataforma BTG") {

    Container(frontend, "Frontend", "SPA", "Interface do usuario")

    Container(api_gateway, "API Gateway", "Spring Cloud Gateway", "Ponto de entrada")

    Container(discovery, "Service Discovery", "Spring Cloud Netflix Eureka", "Registro de servicos")

    Container(ms_customer, "Customer Service", "Spring Boot", "Gestao de clientes")

    Container(ms_order, "Order Service", "Spring Boot", "Gestao de pedidos")

    ContainerDb(mysql, "MySQL 8.4", "Banco relacional", "Persistencia")

    ContainerQueue(rabbitmq, "RabbitMQ", "Broker AMQP", "Mensageria assincrona")

}

Rel(user, frontend, "Usa")

Rel(frontend, api_gateway, "REST")

Rel(api_gateway, discovery, "Resolve servicos")
Rel(api_gateway, ms_customer, "Roteia")
Rel(api_gateway, ms_order, "Roteia")

Rel(ms_customer, discovery, "Registra")
Rel(ms_order, discovery, "Registra")

Rel(ms_customer, mysql, "Le e grava")
Rel(ms_order, mysql, "Le e grava")

Rel(ms_customer, rabbitmq, "Publica eventos")
Rel(ms_customer, rabbitmq, "Consome eventos")
Rel(ms_order, rabbitmq, "Publica eventos")
Rel(ms_order, rabbitmq, "Consome eventos")

Rel(ms_customer, ms_order, "Chamadas sincronas", "OpenFeign/HTTP")

@enduml